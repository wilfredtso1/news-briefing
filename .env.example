# Google OAuth — for user sign-in flow (separate from service-account GMAIL_* vars)
GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REDIRECT_URI=https://[your-domain]/auth/google/callback

# Session cookie signing (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=...

# Unsubscribe link signing (generate same way)
UNSUBSCRIBE_SECRET_KEY=...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-...

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# LangSmith (tracing)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=news-briefing-agent
LANGCHAIN_TRACING_V2=true

# Gmail API
GMAIL_CLIENT_ID=....apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...

# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Gmail sending
GMAIL_SEND_AS=your-gmail-address@gmail.com
